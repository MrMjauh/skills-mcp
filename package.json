{
  "name": "skills-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server that exposes GitHub-hosted skills as tools",
  "bin": {
    "skills-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "npm run build && mcp-inspector node ./dist/index.js",
    "lint": "biome check --write src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@octokit/request-error": "6.0.0",
    "@octokit/rest": "21.0.0",
    "zod": "4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@modelcontextprotocol/inspector": "0.21.0",
    "@types/node": "22.0.0",
    "tsup": "8.0.0",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
